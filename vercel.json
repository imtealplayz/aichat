{
  "version": 2,
  "builds": [
    { "src": "api/chat.js",   "use": "@vercel/node" },
    { "src": "api/name.js",   "use": "@vercel/node" },
    { "src": "api/vision.js", "use": "@vercel/node" },
    { "src": "public/**",     "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat",   "dest": "/api/chat.js" },
    { "src": "/api/name",   "dest": "/api/name.js" },
    { "src": "/api/vision", "dest": "/api/vision.js" },
    { "src": "/(.*)",       "dest": "/public/$1" }
  ]
}
